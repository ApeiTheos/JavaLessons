package javagui;
import javax.swing.*;
import javax.swing.table.DefaultTableModel;
import java.awt.*;
import java.util.*;
import java.io.*;
import java.awt.event.*;


public class StudentInfoForm_Luyaga extends JFrame {
   
	 static JTextField txtname, txtcourse, txtsect;
	 static JButton btnAdd, btnUpd, btnDel, btnCl;
	 static DefaultTableModel model;
	 
	 StudentInfoForm_Luyaga(){
		
		 JLabel lName = new JLabel("Name: ");
		 add(lName).setBounds(5, 10, 40, 20);
		 txtname = new JTextField();
		 add(txtname).setBounds(5, 30, 130, 20);
		 
		 JLabel lCourse = new JLabel("Course: ");
		 add(lCourse).setBounds(145, 10, 60, 20);
		 txtcourse = new JTextField();
		 add(txtcourse).setBounds(145, 30, 130, 20);
		 
		 JLabel lSec = new JLabel("Section: ");
		 add(lSec).setBounds(285, 10, 60, 20);
		 txtsect = new JTextField();
		 add(txtsect).setBounds(285, 30, 130, 20);
		 
		 btnAdd = new JButton("Add");
		 add(btnAdd).setBounds(25, 60, 80, 20);
		 btnUpd = new JButton("Update");
		 add(btnUpd).setBounds(120, 60, 80, 20);
		 btnDel = new JButton("Delete");
		 add(btnDel).setBounds(225, 60, 80, 20);
		 btnCl = new JButton("Clear");
		 add(btnCl).setBounds(320, 60, 80, 20);
		 
		 String columns[] = {"Full Name", "Course", "Section"};
		 model = new DefaultTableModel(columns, 0);
		 JTable table = new JTable(model);
		 JScrollPane scPane = new JScrollPane(table);
		 add(scPane).setBounds(10, 90, 410, 265);
		 
		 table.getTableHeader().setBackground(new Color(173, 216, 230)); 
		 table.getTableHeader().setForeground(Color.BLACK);
		
		 table.addMouseListener(new MouseAdapter(){
				public void mouseClicked(MouseEvent ev) {
				 int row = table.getSelectedRow();
				 if(row != -1) {
					 txtname.setText(model.getValueAt(row, 0).toString()); 
					 txtcourse.setText(model.getValueAt(row, 1).toString()); 
					 txtsect.setText(model.getValueAt(row, 2).toString()); 
				 }
				}
		 });
		 
		 read();
		 
		 btnAdd.addActionListener(e ->{
			 
			    String Fname = txtname.getText();
			    String Course = txtcourse.getText();
			    String Section = txtsect.getText();
			   			    
			 try {
					FileWriter fw = new FileWriter("studentInfo.txt", true);
					
					fw.write(Fname + " - " + Course + " - " +  Section + "\n");
					fw.close();
					
					read();
					JOptionPane.showMessageDialog(null, "Info Added Successfully!"); 
					
			 } catch (IOException e1) {
				 System.out.println("System Error: " + e1.getMessage());
			 }
		 });
		 
		 btnUpd.addActionListener(e ->{
			 int selectRow = table.getSelectedRow();
				
				if(selectRow == -1) {
					JOptionPane.showMessageDialog(null, "Select a record to update.");
					return;
				}
				
				ArrayList<String> lists = new ArrayList<>();
				try(BufferedReader br = new BufferedReader(new FileReader("studentInfo.txt"))){
				 String line;  int rowInd = 0;				 				
				 
				 while((line = br.readLine()) != null) {
					if(rowInd == selectRow) {
						String update = txtname.getText() + " - " +
						                txtcourse.getText() + " - " +
						                txtsect.getText();
						lists.add(update);
					} else {
						lists.add(line);
					}
					rowInd++;
				 }
				}catch(IOException z) {
					System.err.println(z);
				}
				
				try (BufferedWriter bw = new BufferedWriter(new FileWriter("studentInfo.txt"))) {
					
					for(String record : lists) bw.write(record + "\n");
					} catch(IOException z) {
						System.out.println(z);
					}
				
				read();
				JOptionPane.showMessageDialog(null, "Updated Successfully!");							
		 });
		 
		 btnDel.addActionListener(e ->{
				int selectRow = table.getSelectedRow();
				
				if(selectRow == -1) {
					JOptionPane.showMessageDialog(null, "Select a record to delete.");
					return;
				}
				
				int confirm = JOptionPane.showConfirmDialog(null, "Are you sure to delete this record?",
						"Confirm Delete", JOptionPane.YES_NO_OPTION);
				if(confirm != JOptionPane.YES_OPTION) return;
				
				ArrayList<String> lists = new ArrayList<>();
				try(BufferedReader br = new BufferedReader(new FileReader("studentInfo.txt"))){
				 String line;  int rowInd = 0;
				 
				 while((line = br.readLine()) != null) {
					if(rowInd != selectRow) lists.add(line); 
					rowInd++;
				 }
				}catch(IOException z) {
					System.err.println(z);
				}
				
				try (BufferedWriter bw = new BufferedWriter(new FileWriter("studentInfo.txt"))) {
					
					for(String record : lists) bw.write(record + "\n");
					} catch(IOException z) {
						System.out.println(z);
					}
				
				read();
				JOptionPane.showMessageDialog(null, "Deleted Successfully!");
			
			 });

	 
	 btnCl.addActionListener(e->{
	  txtname.setText(""); 
	  txtcourse.setText(""); 
	  txtsect.setText(""); 
	 });
		
	 setTitle("Student Information Form");
	 setLayout(null);
	 setSize(445, 405);
	 setDefaultCloseOperation(EXIT_ON_CLOSE);
	 setVisible(true);
	}
	
	
	 public static void read() {
			model.setRowCount(0);
			
			try (BufferedReader br = new BufferedReader(new FileReader("studentInfo.txt"))) {
			String line;
			
			while((line = br.readLine()) != null) {
				String row[] = line.split(" - ");
				model.addRow(row);
			}
			} catch(IOException e) {
				System.out.println("System Error: " + e.getMessage());
			}
		}
	
	public static void main(String[] args) {
	new	StudentInfoForm_Luyaga();

	}

}
